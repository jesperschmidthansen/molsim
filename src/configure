#!/bin/sh

set -eu

MAKEFILE=Makefile

# Octave pkg usually provides MKOCTFILE in the environment.
# Fall back to mkoctfile if not set.
MKOCTFILE="${MKOCTFILE:-mkoctfile}"

if ! command -v "$MKOCTFILE" >/dev/null 2>&1; then
    echo "Error: mkoctfile not found." >&2
    exit 1
fi

# Query the compilers Octave itself uses.
cc_cmd=$("$MKOCTFILE" -p CC 2>/dev/null || echo "")
cxx_cmd=$("$MKOCTFILE" -p CXX 2>/dev/null || echo "")

# Keep only the executable name, without path or extra arguments.
cc_name=$(printf '%s\n' "$cc_cmd"  | awk '{print $1}' | sed 's|.*[/\\]||')
cxx_name=$(printf '%s\n' "$cxx_cmd" | awk '{print $1}' | sed 's|.*[/\\]||')

FLAGS=""

# Add GCC-only flags.
for c in "$cc_name" "$cxx_name"; do
    case "$c" in
        gcc|g++|gcc-*|g++-*)
            FLAGS="-Wall -Wextra -Ofast"
            break
            ;;
    esac
done

cat > "$MAKEFILE" <<EOF
CC = $MKOCTFILE
FLAGS = $FLAGS

srcm = \$(wildcard *.c)
mexs = \$(srcm:.c=.mex)

srco = \$(wildcard *.cpp)
octs = \$(srco:.cpp=.oct)

all: \$(mexs) \$(octs)

%.mex: %.c
	\$(CC) \$(FLAGS) --mex \$< -o \$@

%.oct: %.cpp
	\$(CC) \$(FLAGS) \$< -o \$@

clean:
	rm -f *.mex *.oct ms*.m
EOF

exit 0
